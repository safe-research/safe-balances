# Ethereum mainnet RPC access, used to read the vesting and staking contracts.
# A free public gateway works fine (must support eth_getLogs):
ETH_RPC_URL=https://mainnet.gateway.tenderly.co

# Alternative: set an Infura project ID instead (builds https://mainnet.infura.io/v3/<key>).
# Only used if ETH_RPC_URL is not set.
# INFURA_API_KEY=
